rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Profiles ───
    // Each user can only read/write their own profile document
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Polls ───
    // Anyone signed in can read polls; writing restricted to authenticated users
    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Worship Challenge ───
    // Users can only access their own challenge data
    match /worshipUpgrade/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Game Scores ───
    // Users can read all scores (leaderboard) but only write their own
    match /bibleBingoScores/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Public Content (read-only) ───
    match /publicContent/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}